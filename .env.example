# 复制为 .env 后按需修改。docker compose 运行时这些值由 compose 注入（指向服务名）。
# 下列默认值适用于"在宿主机直接跑 app、依赖用 docker compose 起"的本地开发场景。
# 主机用 127.0.0.1（而非 localhost）强制走 IPv4：规避 Docker Desktop/WSL2 在 [::1] 上的
# 端口转发（wslrelay）偶发回 502 的问题。端口为 compose 暴露的 182xx 段。

# 国内网络加速。删除或留空即可恢复官方源。
DOCKERHUB_REGISTRY=docker.m.daocloud.io
# TRUSTGUARD_NETWORK_PROXY=http://localhost:7890
UV_DEFAULT_INDEX=https://pypi.tuna.tsinghua.edu.cn/simple
UV_EXTRA_INDEX_URL=
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_EXTRA_INDEX_URL=
HF_ENDPOINT=https://hf-mirror.com
HF_HUB_DISABLE_XET=1

RAG_APP_ENV=dev
RAG_LOG_LEVEL=INFO
RAG_API_PORT=18200

# MySQL
RAG_MYSQL_HOST=127.0.0.1
RAG_MYSQL_PORT=18210
RAG_MYSQL_USER=rag
RAG_MYSQL_PASSWORD=rag
RAG_MYSQL_DB=rag_platform

# Qdrant
RAG_QDRANT_HOST=127.0.0.1
RAG_QDRANT_PORT=18214

# OpenSearch（本地 Compose 关闭安全插件，仅用于开发环境）
RAG_OPENSEARCH_HOST=127.0.0.1
RAG_OPENSEARCH_PORT=18216
RAG_OPENSEARCH_USE_SSL=false
RAG_OPENSEARCH_VERIFY_CERTS=false
RAG_SEARCH_OPENSEARCH_MOCK=false
RAG_OPENSEARCH_BACKFILL_ON_STARTUP=true
OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m
OPENSEARCH_MEM_LIMIT=1g

# Redis
RAG_REDIS_HOST=127.0.0.1
RAG_REDIS_PORT=18211

# RabbitMQ
RAG_RABBITMQ_HOST=127.0.0.1
RAG_RABBITMQ_PORT=18212
RAG_RABBITMQ_USER=guest
RAG_RABBITMQ_PASSWORD=guest
RAG_RABBITMQ_VHOST=/
RAG_RABBITMQ_EXCHANGE=rag.commands
RAG_RABBITMQ_DEAD_EXCHANGE=rag.dead
RAG_RABBITMQ_PREFETCH_COUNT=1
RAG_RABBITMQ_CONSUMER_MAX_RETRIES=5
RAG_RABBITMQ_RETRY_DELAYS_MS=10000,60000,300000
RAG_WORKER_OUTBOX_POLL_SECONDS=1
RAG_WORKER_OUTBOX_BATCH_SIZE=50
RAG_WORKER_OUTBOX_LEASE_SECONDS=60
RAG_WORKER_JOB_LEASE_SECONDS=120
RAG_WORKER_HEARTBEAT_SECONDS=30
RAG_WORKER_RECOVERY_SCAN_SECONDS=15
RAG_WORKER_INDEXING_STALE_SECONDS=300
# 仅供测试使用；生产环境必须保持 false
RAG_WORKER_EAGER=false

# 对象存储（MinIO 为默认；关闭时回退本地目录）
RAG_MINIO_ENABLED=true
RAG_MINIO_ENDPOINT=127.0.0.1:18217
RAG_MINIO_ACCESS_KEY=minioadmin
RAG_MINIO_SECRET_KEY=minioadmin
RAG_MINIO_BUCKET=rag-artifacts
RAG_LOCAL_STORAGE_DIR=./data/storage

# Qdrant（mock 模式下不连真实 Qdrant，索引操作为 no-op）
RAG_QDRANT_MOCK=true
RAG_QDRANT_HOST=127.0.0.1
RAG_QDRANT_PORT=18214

# Ingest
RAG_MODE=ingest
RAG_INGEST_MAX_PDF_BYTES=52428800
RAG_INGEST_MAX_FILE_BYTES=52428800
RAG_INGEST_MAX_PDF_PAGES=500
RAG_CONFLICT_TTL_HOURS=168
RAG_CHUNK_TOKENIZER_MODEL=Qwen/Qwen3-Embedding-0.6B
RAG_CHUNK_TARGET_TOKENS=384
RAG_CHUNK_OVERLAP_TOKENS=64

# OCR：none | local(Paddle) | api
RAG_OCR_PROVIDER=none
RAG_OCR_API_DRIVER=openai_compatible
RAG_OCR_LANG=ch
RAG_OCR_FAIL_OPEN=true
RAG_OCR_RENDER_DPI=144
# RAG_OCR_API_BASE_URL=
# RAG_OCR_API_KEY=
# RAG_OCR_API_MODEL=qwen-vl-ocr
# Custom OCR：
# RAG_OCR_CUSTOM_BASE_URL=
# RAG_OCR_CUSTOM_PATH=/ocr
# RAG_OCR_CUSTOM_REQUEST_TEMPLATE=multipart
# RAG_OCR_CUSTOM_RESPONSE_JSONPATH=$.text
# 本地联调 custom OCR 指向内网时才打开：
# RAG_OCR_ALLOW_PRIVATE_URLS=false

# 文档解析：local 保留本地 PDF 文本层 + OCR；mineru 让 PDF 也走 MinerU
RAG_PDF_PARSER=mineru
# DOCX 始终使用 MinerU；宿主机访问 compose 服务的端口为 18220
RAG_MINERU_BASE_URL=http://127.0.0.1:18220
RAG_MINERU_DOCKER_BASE_URL=http://mineru-api:8000
RAG_MINERU_BACKEND=pipeline
RAG_MINERU_TIMEOUT_SECONDS=300

# MinerU Docker 构建与 GPU。首次构建会下载较大的 CUDA 镜像和模型。
MINERU_IMAGE=trustguard-mineru:latest
# pipeline 默认不需要 vLLM；使用 vLLM engine 时可覆盖为官方 vllm 镜像
MINERU_BASE_IMAGE=${DOCKERHUB_REGISTRY}/library/python:3.11-slim
MINERU_PACKAGE_SPEC=mineru[core]==3.4.4
MINERU_MODEL_SOURCE=modelscope
# pipeline 后端只下载 pipeline 模型；使用 VLM 后端时再改为 all 或 vlm
MINERU_MODEL_TYPE=pipeline
UBUNTU_APT_MIRROR=https://mirrors.tuna.tsinghua.edu.cn/ubuntu
MINERU_GPU_DEVICE_ID=0
MINERU_API_MAX_CONCURRENT_REQUESTS=1
MINERU_PDF_RENDER_TIMEOUT=300

# Embedding（Docker 默认安装本地推理依赖并使用本地模型）
RAG_EMBEDDING_PROVIDER=local
RAG_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
RAG_EMBEDDING_DIM=1024
RAG_EMBEDDING_DEVICE=auto
RAG_EMBEDDING_BATCH_SIZE=10
RAG_EMBEDDING_NORMALIZE=true
RAG_EMBEDDING_QUERY_INSTRUCTION=Given a cybersecurity search query, retrieve relevant passages that answer the query

# 本地模型下载源：huggingface | modelscope（仅 RAG_EMBEDDING_PROVIDER=local 时使用）
# RAG_EMBEDDING_DOWNLOAD_SOURCE=huggingface
# RAG_HUGGINGFACE_ENDPOINT=https://hf-mirror.com
# RAG_HUGGINGFACE_HUB_URL=https://hf-mirror.com
# RAG_EMBEDDING_CACHE_DIR=./data/models/huggingface

# 魔塔下载源示例
# RAG_EMBEDDING_DOWNLOAD_SOURCE=modelscope
# RAG_MODELSCOPE_ENDPOINT=https://www.modelscope.cn
# RAG_MODELSCOPE_CACHE_DIR=./data/models/modelscope

# base_url 格式参考百炼文档：
# https://{WorkspaceId}.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
# RAG_EMBEDDING_BASE_URL=https://YOUR_WORKSPACE_ID.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
# RAG_EMBEDDING_API_KEY=YOUR_BAILIAN_API_KEY
# RAG_EMBEDDING_API_TIMEOUT_SECONDS=60

# Rerank（provider 与 Embedding 一致：none | local | api）
RAG_RERANK_PROVIDER=none
RAG_RERANK_TOP_K=10

# 百炼 OpenAI-compatible rerank API 示例
# RAG_RERANK_PROVIDER=api
# RAG_RERANK_MODEL=qwen3-rerank
# RAG_RERANK_BASE_URL=https://YOUR_WORKSPACE_ID.cn-beijing.maas.aliyuncs.com/compatible-api/v1
# RAG_RERANK_API_KEY=YOUR_BAILIAN_API_KEY
# RAG_RERANK_API_TIMEOUT_SECONDS=60
# RAG_RERANK_INSTRUCTION=Given a web search query, retrieve relevant passages that answer the query.

# 回答生成（默认关闭；启用后提供 POST /v1/answer）
RAG_LLM_PROVIDER=none
# RAG_LLM_PROVIDER=openai_compatible
# RAG_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# RAG_LLM_API_KEY=YOUR_LLM_API_KEY
# RAG_LLM_MODEL=qwen-plus
# RAG_LLM_TIMEOUT_SECONDS=60
# RAG_LLM_TEMPERATURE=0.1
# RAG_LLM_MAX_OUTPUT_TOKENS=1024
# RAG_LLM_JSON_RESPONSE_FORMAT=true
RAG_ANSWER_CONTEXT_MAX_TOKENS=6000
RAG_ANSWER_MAX_CONTEXT_CHUNKS=8
RAG_ANSWER_REFUSAL_MESSAGE=当前知识库中没有足够证据回答该问题。
